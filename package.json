{
  "name": "litopys-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "author": "Denis Blashchytsia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/litopys-dev/litopys.git"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun run --filter='*' typecheck",
    "build:binary": "bun build --compile --minify --target=bun-linux-x64 --outfile=dist/litopys packages/cli/src/index.ts",
    "build:all": "bun scripts/build-all.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
